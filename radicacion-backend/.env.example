APP_NAME="Radicación Monterrey"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://radicacion-api.railway.app

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=radicacion
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Storage Railway Volume — montar en Railway en /app/storage
STORAGE_PATH=/app/storage

# Sanctum SPA
SANCTUM_STATEFUL_DOMAINS=radicacion.railway.app,localhost:5173,localhost:4173
FRONTEND_URL=https://radicacion.railway.app

# IA — Gemini Flash 2.5
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Correos — Brevo API REST (no SMTP)
BREVO_API_KEY=
SMTP_FROM_NAME="Alcaldía de Monterrey Casanare"
SMTP_FROM=noreply@alcaldiamontereycasanare.gov.co

# CDR (Certificado de Residencia Digital) — integración peer-to-peer de
# solicitudes de Carta de Residencia (tipo_correspondencia_id = 90).
# CDR_API_TOKEN se usa en AMBAS direcciones: VUR lo manda como Bearer al
# llamar a CDR (ClienteCdr) y CDR debe mandar el mismo valor como Bearer al
# llamar a VUR POST /api/v1/solicitudes-carta-residencia (EnsureCdrServiceToken).
CDR_API_URL=
CDR_API_TOKEN=
VUR_TIPO_CORRESPONDENCIA_RESIDENCIA_ID=90
# Email del usuario "de sistema" sembrado por la migración
# seed_cdr_sistema_user; queda como operador_id de los radicados creados por
# el intake de CDR. Normalmente no hace falta tocarlo.
CDR_OPERADOR_EMAIL=sistema.cdr@monterrey.gov.co
